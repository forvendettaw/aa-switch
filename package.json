{
  "name": "aa-switch",
  "version": "1.0.0",
  "description": "All-Agent Switch - Local Context Gateway",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aa-switch": "./dist/cli/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/cli/index.ts",
