{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aa-switch",
  "version": "1.0.0",
  "identifier": "com.aa-switch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "aa-switch",
        "width": 400,
        "height": 600,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": true,
        "minWidth": 320,
        "minHeight": 400
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/*",
      "../dist/*"
    ]
  }
}
